# --- Jira (self-hosted Server / Data Center) ---
# Base URL of your Jira instance, no trailing slash, e.g. https://jira.example.com
JIRA_BASE_URL=
# Personal Access Token (Jira 8.14+ Data Center PAT, sent as Bearer token)
JIRA_PAT=
# Project key the pipeline operates on, e.g. SENT
JIRA_PROJECT_KEY=

# --- LiteLLM (all AI calls are routed here, OpenAI-compatible API) ---
# e.g. https://litellm.example.com  (the /v1 suffix is added automatically if missing)
LITELLM_BASE_URL=
LITELLM_API_KEY=

# Default model name as known by your LiteLLM deployment
SENTINEL_DEFAULT_MODEL=gpt-4o
# Code Reviewer must run on a different model than the Implementer (role 08 doc).
# Leave empty to fall back to the default model (separate context only).
SENTINEL_REVIEWER_MODEL=

# --- Sentinel service ---
# Jira webhook secret guarding only POST /webhook/jira.
# Recommended production URL: https://<sentinel-host>/webhook/jira?token=<WEBHOOK_SECRET>
# (Jira Server/DC webhooks commonly need the legacy query token). Keep the service
# behind TLS/private-network controls; do not expose plain HTTP beyond a local proxy.
# Leave empty to accept Jira webhooks UNAUTHENTICATED (development only — logs a warning).
WEBHOOK_SECRET=

# Separate operator/admin token for /sweep, /pause, /resume, /audit and /ops.json.
# Present it as `Authorization: Bearer <SENTINEL_ADMIN_TOKEN>` or `X-Sentinel-Token`.
# If empty, these admin endpoints fail closed until configured.
SENTINEL_ADMIN_TOKEN=

# Outbound alert webhook. When set, Sentinel POSTs a JSON message here every time
# the pipeline needs a human — agent/orchestrator escalations and pipeline pause/
# resume — so you are pinged instead of having to watch the Jira board. The payload
# is Slack-compatible (a Slack incoming-webhook URL works out of the box; the
# readable line is in `text`) and carries structured event/ticket/url fields for
# generic consumers. Leave empty to disable (Jira comment + needs-human label only).
SENTINEL_ALERT_WEBHOOK_URL=

# Where audit log + agent workspaces live inside the container (compose mounts a volume here)
DATA_DIR=/data

# Optional overrides (defaults shown)
#SENTINEL_SWEEP_INTERVAL=900          # full board sweep, seconds
#SENTINEL_LEASE_TIMEOUT=1800          # reclaim leases silent for this long, seconds
#SENTINEL_HEARTBEAT_INTERVAL=600      # lease heartbeat cadence, seconds
#SENTINEL_MAX_AGENT_TURNS=80          # hard cap on LLM tool-loop iterations per run
#SENTINEL_JIRA_MAX_RETRIES=3          # retries on transient Jira errors (429/502/503/504, network blips)
#SENTINEL_AUDIT_MAX_BYTES=50000000    # rotate /data/audit.jsonl past this size; 0 = unbounded single file
#SENTINEL_AUDIT_BACKUP_COUNT=5        # rotated generations to keep (audit.jsonl.1 .. .N)
#SENTINEL_SHUTDOWN_GRACE=10           # seconds to let in-flight agents release their leases on stop
#SENTINEL_STALE_ESCALATION_HOURS=24   # re-alert on tickets left frozen (needs-human) this long; 0 disables
#SENTINEL_LLM_DAILY_TOKEN_BUDGET=0    # pause the pipeline when a UTC day's LLM tokens exceed this; 0 disables.
                                      # Resume is manual (POST /resume) — a blown budget means something ran away.
#SENTINEL_WORKSPACE_MAX_BYTES=0       # wipe an idle shell-role workspace past this size (bytes); 0 disables.
                                      # Project commands must tolerate a fresh workspace (clone-if-missing).
#SENTINEL_LOG_LEVEL=INFO
